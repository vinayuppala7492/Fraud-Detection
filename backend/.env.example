# ============================================
# BACKEND ENVIRONMENT VARIABLES
# Flask API Configuration
# ============================================

# Flask Configuration (Optional - uncomment if using sessions/cookies)
# SECRET_KEY=your_secret_key_here_generate_with_python_secrets_token_hex_32

# Server Configuration
# HOST=0.0.0.0
# PORT=5000
# FLASK_ENV=production

# Database Configuration (if using external DB in future)
# DATABASE_URL=sqlite:///results.db

# CORS Configuration (if restricting origins in production)
# ALLOWED_ORIGINS=https://your-frontend-domain.vercel.app,https://your-custom-domain.com

# Model Paths (if different from defaults)
# SCALER_PATH=saved_models/scaler.pkl
# THRESHOLD_PATH=saved_models/threshold.pkl
# AUTOENCODER_PATH=saved_models/autoencoder_model.pth
# GRAPHSAGE_PATH=saved_models/graphsage_model.pth

# Logging Configuration
# LOG_LEVEL=INFO
# LOG_FILE=app.log

# Notes:
# - Most configurations have sensible defaults in app.py
# - Only create a .env file if you need to override defaults
# - Never commit .env files with sensitive data to version control
# - For production, use your hosting platform's environment variable system
