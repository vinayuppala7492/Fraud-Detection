# ============================================
# BACKEND .GITIGNORE - Flask ML API
# ============================================

# Python Cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual Environment
venv/
env/
ENV/
.venv/
virtualenv/

# Environment Variables (CRITICAL)
.env
.env.local
*.env

# Flask Instance Folder
instance/
.webassets-cache

# Large Dataset Files (143+ MB - Exceeds GitHub Limit)
dataset/*.csv
!dataset/.gitkeep
# Keep sample file
!sample_batch.csv

# Model Files (if they exceed 100MB, use Git LFS)
# Current files are small, so we keep them:
# - autoencoder_model.pth: 0.01 MB
# - graphsage_model.pth: 0.03 MB
# - scaler.pkl: < 0.01 MB
# - threshold.pkl: < 0.01 MB
# Uncomment below if models become large:
# saved_models/*.pth
# saved_models/*.pkl

# Training Artifacts
lightning_logs/
tensorboard_logs/
runs/
checkpoints/
*.ckpt

# Jupyter Notebooks
.ipynb_checkpoints/
*.ipynb

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS Files
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Test Coverage
.coverage
htmlcov/
.pytest_cache/

# Distribution
dist/
build/
*.egg-info/
