# Backend API URL
# For local development, use http://localhost:5000 or http://127.0.0.1:5000
# For production (Vercel), use your deployed backend URL (e.g., https://your-api.herokuapp.com)
VITE_API_URL=http://localhost:5000

# Firebase Configuration
# Get these values from your Firebase Console > Project Settings > General
# Firebase is used for authentication and Firestore database
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id
